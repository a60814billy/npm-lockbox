{
  "name": "npm-lockbox",
  "version": "0.0.1-alpha.0",
  "description": "manage and restrict npm dependencies with specific versions or date",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "test": "mocha -r ts-node/register -r tsconfig-paths/register ./tests/**/*.test.ts --exit --recursive"
  },
  "keywords": [
    "npm",
    "dependency",
    "lockbox"
  ],
  "author": "Raccoon Li <a60814billy@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.18",
    "@types/mocha": "8.2.2",
    "@types/node": "^10.17.60",
    "@types/semver": "^7.5.3",
    "mocha": "8.4.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "4.9.5"
  },
  "nodemonConfig": {
    "verbose": true,
    "exec": "ts-node ./src/index.ts",
    "watch": [
      "src/**"
    ],
    "ext": "ts,js,json"
  }
}
