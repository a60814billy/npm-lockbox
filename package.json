{
  "name": "npm-lockbox",
  "version": "0.0.1-alpha.0",
  "description": "manage and restrict npm dependencies with specific versions or date",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon",
    "build": "npm run build:frontend && tsc",
    "build:frontend": "vite build --config frontend/vite.config.mjs",
    "test": "TS_NODE_PREFER_TS_EXTS=true mocha -r ts-node/register -r tsconfig-paths/register ./tests/**/*.test.ts --exit --recursive"
  },
  "keywords": [
    "npm",
    "dependency",
    "lockbox"
  ],
  "author": "Raccoon Li <a60814billy@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mocha": "8.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.5.3",
    "@vitejs/plugin-react": "^4.3.4",
    "mocha": "8.4.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "4.9.5",
    "vite": "^4.5.3"
  },
  "nodemonConfig": {
    "verbose": true,
    "exec": "ts-node ./src/index.ts",
    "watch": [
      "src/**"
    ],
    "ext": "ts,js,json"
  }
}
